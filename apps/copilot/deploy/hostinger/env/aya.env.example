NODE_ENV=production
PORT=3010
AYA_DATA_DIR=/app/data

LOG_LEVEL=info
AUDIT_STDOUT_MODE=metadata
ENABLE_BLUE_POLLING=true
BLUE_INGEST_INTERVAL_MS=300000
WORKSPACE_FULL_RECONCILE_HOURS=4
BLUE_GRAPHQL_TIMEOUT_MS=15000
ALLOW_DEV_DEFAULT_ACTOR=false
ALLOW_SYSTEM_BLUE_WRITE_FALLBACK=false
ALLOW_BOOTSTRAP_PROVISIONING=false

# Only required if bootstrap provisioning is explicitly enabled in non-production.
AUTH_BOOTSTRAP_KEY=
AYA_MCP_API_KEY=replace-with-shared-internal-key
AYA_HOSTINGER_MCP_API_KEY=replace-with-separate-hostinger-internal-key
OPENAI_API_KEY=replace-with-openai-api-key
AYA_CHAT_RUNTIME=agent_with_planner_fallback
AYA_AGENT_MODEL=gpt-4o
AYA_AGENT_MAX_STEPS=5
AYA_AGENT_TIMEOUT_MS=30000
AYA_LLM_PLANNER_ENABLED=true
AYA_LLM_PLANNER_MODEL=gpt-4o-mini
AYA_LLM_PLANNER_TIMEOUT_MS=2500

BLUE_WORKSPACE_ID=cmhazc4rl1vkand1eonnmiyjy
BLUE_API_URL=https://api.blue.cc/graphql
BLUE_AUTH_TOKEN=replace-me
BLUE_CLIENT_ID=replace-me
BLUE_COMPANY_ID=replace-me

# Required in production. Route this public URL to Aya's /webhooks/blue endpoint.
BLUE_WEBHOOK_PUBLIC_URL=https://copilot.ayafinancial.com/webhooks/blue
BLUE_WEBHOOK_SECRET=replace-me

LIBRECHAT_MONGO_URI=mongodb://aya_mongo_root:replace-with-mongo-password@mongodb:27017/LibreChat?authSource=admin
LIBRECHAT_MONGO_DB_NAME=LibreChat
